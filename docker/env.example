# 复制为 docker/.env 后按需修改
# cp docker/env.example docker/.env

# 服务端口（host 网络下直接占用宿主机端口，无 ports 映射）
MILOCO_SERVER_PORT=1810
MILOCO_AGENT_PORT=18789
MILOCO_AGENT_WEBHOOK_URL=http://127.0.0.1:18789/miloco/webhook

# 本地 MILOCO_HOME 目录（bind mount 到容器 /data/miloco）
# 相对路径相对于 docker/ 目录；也可用绝对路径，例如 ~/.openclaw/miloco
MILOCO_DATA_DIR=./data

# 感知 Omni（可选；不填则保留 config.json 内已有配置）
MILOCO_OMNI_API_KEY=
MILOCO_OMNI_BASE_URL=https://api.xiaomimimo.com/v1
MILOCO_OMNI_MODEL=xiaomi/mimo-v2.5
